  - {fileID: 2037886625}
  - {fileID: 2037886625}
  - {fileID: 1724245033}
  - {fileID: 2037886625}
  bossSentence1:
  - "\uADF8\uB798\u2026 \uB124\uAC00 \uADF8 \u201C\uB514\uD50C\uB85C\u201D \uB77C\uB294
    \uB140\uC11D\uC778\uAC00\u2026?"
  - "\uBB34\uC2A8 \uC6A9\uAC74\uC778\uC9C0 \uC774\uC57C\uAE30\uB098 \uD55C\uBC88
    \uB4E4\uC5B4\uBCF4\uC9C0."
  - "\uC81C \uAE30\uC5B5\uC5D0 \uCC3E\uAE30 \uC704\uD574\uC11C \uC654\uC2B5\uB2C8\uB2E4.
    \uB124\uAC00\uC9C0 \uBB38\uC591\uC744 \uC5BB\uC73C\uBA74 \uC18C\uC6D0\uC744 \uC774\uB8E8\uC5B4\uC900\uB2E4\uB294
    \uC774\uC57C\uAE30\uB97C \uB4E3\uACE0 \uBB38\uC591\uC744 \uC5BB\uAE30 \uC704\uD574\uC11C
    \uCC3E\uC544\uC654\uC2B5\uB2C8\uB2E4."
  - "\uBB38\uC591\u2026\uC744\u2026 \uB124\uB188\uC774 \uC5B4\uB5BB\uAC8C \uC54C\uACE0\uC788\uB294\uAC70\uC9C0?"
  - "\uC804 \uC81C \uAE30\uC5B5\uC744 \uAF2D \uB418\uCC3E\uACE0\uC2F6\uC2B5\uB2C8\uB2E4.
    \uBB38\uC591\uC744 \uB118\uACA8\uC8FC\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
  - "\uD55C\uB0B1 \uD53C\uB77C\uBBF8 \uAC19\uC740 \uB124\uB188\uC758 \uAE30\uC5B5
    \uD558\uB098 \uB54C\uBB38\uC5D0 \uBB38\uC591\uC744 \uB118\uAE38\uC218\uB294 \uC5C6\uC9C0."
  bossName1:
  - "\uD0B9"
  - "\uD0B9"
