  - {fileID: 2037886625}
  bossSentence2:
  - "\uD06C\uC73C\uC73D.. \uC774\uB807\uAC8C\uAE4C\uC9C0 \uB9C9\uC73C\uC2DC\uB294
    \uC774\uC720\uAC00 \uBB61\uB2C8\uAE4C!"
  - "\uB124\uB140\uC11D\uC740 \uACAC\uB51C\uC218 \uC5C6\uB294 \uC9C4\uC2E4\uACFC
    \uD798\uC774 \uC874\uC7AC\uD558\uC9C0\u2026 \uC544\uB9C8 \uB124\uB140\uC11D\uC758
    \uAE30\uC5B5\uC5D0 \uB300\uD55C \uC815\uBCF4\uB3C4 \uB2E4\uB978 \uBB38\uC591\uB4E4\uC5D0
    \uB098\uB220\uC838 \uB2F4\uACA8\uC788\uC744\uAC70\uB2E4\u2026"
  - '!!!!!!'
  - "\uB124\uB140\uC11D\uC774 \uC815\uB9D0\uB85C \uAE30\uC5B5\uC744 \uB418\uCC3E\uACE0\uC2F6\uB2E4\uBA74\u2026
    \uB118\uACA8\uC8FC\uB3C4\uB85D \uD558\uC9C0. \uC2E4\uB825\uC744 \uBCF4\uB2C8
    \uC800\uBC88\uBCF4\uB2E4\uB294 \uC131\uC7A5\uD55C\uAC74\uAC00."
  - "\uC800\uBC88..\uC774\uB77C\uB2C8 \uADF8\uAC8C \uBB34\uC2A8\uC18C\uB9BD\uB2C8\uAE4C?"
  - "\uADF8\uAC8C \uD798\uC758 \uC0C1\uC9D5, \uC2A4\uD398\uC774\uB4DC\uC758 \uBB38\uC591\uC774\uB2E4. "
  - "\uBB38\uC591\uC744\u2026\uB118\uACA8\uC8FC\uC2DC\uB294\uAC81\uB2C8\uAE4C??"
  - "\uAE30\uC5B5\uC744 \uB418\uCC3E\uACE0\uC790 \uD558\uB294 \uC758\uC9C0\uAC00
    \uB0B4 \uC0DD\uAC01\uC774\uC0C1\uC73C\uB85C \uAC15\uD588\uACE0, \uC5B4\uB5A4
    \uB9AC\uC2A4\uD06C\uB3C4 \uAC10\uC218\uD558\uACE0\uC790 \uD558\uB294 \uC758\uC9C0\uAC00
    \uBCF4\uC774\uB294\uAD70. \uB0A8\uC740 \uBB38\uC591\uB4E4\uC744 \uC5BB\uB294\uAC83\uB3C4
    \uD638\uB77D\uD638\uB77D\uD558\uC9C4 \uC54A\uACA0\uC9C0\uB9CC, \uAC00\uC838\uAC00\uB3C4\uB85D
    \uD574\uB77C."
  - "\uD0B9\uC758 \uBBFF\uC74C\uC744 \uC800\uBC84\uB9AC\uC9C0\uC54A\uACA0\uC2B5\uB2C8\uB2E4..
    \uBBFF\uC5B4\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4."
  bossName2:
  - "\uB514\uD50C\uB85C"
  - "\uD0B9"
  - "\uB514\uD50C\uB85C"
  - "\uD0B9"
