  - {fileID: 245437993}
  - {fileID: 1724245033}
  villageSentence3:
  - "\uC800\uAE30\uC788\uB2E4! \uC7A1\uC544\uB77C! "
  - "\uC774\uC820 \uB9DD\uC124\uC774\uC9C0 \uC54A\uACA0\uC5B4. \uB6AB\uACE0 \uAC04\uB2E4!"
  villageSceneName3:
  - "\uACBD\uBE44\uBCD1"
  - "\uB514\uD50C\uB85C"
  villageImage3:
  - {fileID: 1724245033}
  - {fileID: 245437993}
  castleEntSentence1:
  - "\uC131\uC5D0\uB294 \uC9C4\uC785\uD558\uC9C0 \uBABB\uD558\uAC8C \uD574\uB77C! "
  - "\uD0B9\uC5D0\uAC8C \uAF2D \uBB3C\uC5B4\uBD10\uC57C\uACA0\uC2B5\uB2C8\uB2E4.
    \uBB38\uC591\uACFC \uC18C\uBB38\uC5D0 \uB300\uD574\uC11C! \uADF8\uB9AC\uACE0
    \uB2E4\uB978 \uBB38\uC591\uB4E4\uC5D0 \uB300\uD574\uC11C\uB3C4!"
  castleEntName1:
  - "\uACBD\uBE44\uBCD1"
  - "\uB514\uD50C\uB85C"
  castleEntImage1:
  - {fileID: 1724245033}
  - {fileID: 245437993}
  castleEntSentence2:
  - "\uC5EC\uAE30\uAC00 \uD0B9\uC758 \uC131\uC778\uAC00\u2026? \uD655\uC2E4\uD788
    \uAC15\uD55C \uD798\uC774 \uB290\uAEF4\uC9C0\uB294\uAC78"
  castleEntName2:
  - "\uB514\uD50C\uB85C"
  castleEntImage2:
  - {fileID: 245437993}
  castleEntSentence3:
  - "\uC5EC\uAE30\uAE4C\uC9C0\uB294 \uAC1D\uAE30\uB85C \uBD10\uC8FC\uACA0\uC9C0\uB9CC,
    \uB354 \uC774\uC0C1\uC740 \uC548\uB41C\uB2E4. \uC18C\uB144. \uB3CC\uC544\uAC00\uB77C."
  - "\uD0B9\uC5D0\uAC8C \uC9C1\uC811 \uBB3C\uC5B4\uBCF4\uAE30 \uC804\uAE4C\uC9C0\uB294
    \uBA48\uCD94\uC9C0\uC54A\uC744\uAC81\uB2C8\uB2E4. \uBE44\uD0A4\uC2ED\uC1FC!"
  - "\uC81C \uC783\uC5B4\uBC84\uB9B0 \uAE30\uC5B5\uC744 \uAF2D \uC54C\uC544\uB0B4\uC57C\uACA0\uC2B5\uB2C8\uB2E4!"
  - "\uADF8\uB807\uB2E4\uBA74 \uBCF8\uB54C\uB97C \uBCF4\uC5EC\uC8FC\uACA0\uB2E4!"
  - "\uAC70\uAE30\uAE4C\uC9C0..."
  - "\uB140\uC11D\uC744 \uC548\uC73C\uB85C \uB4E4\uC5EC\uB77C."
  - "\uD558\uC9C0\uB9CC \uC774\uC790\uB294\u2026"
  - "\uADF8\uB0E5 \uB4E4\uC774\uB3C4\uB85D \uD574\uB77C. \uB0B4\uAC00 \uD310\uB2E8\uD558\uACA0\uB2E4."
  castleEntName3:
  - "\uBCD1\uC0AC"
  - "\uB514\uD50C\uB85C"
  - "\uB514\uD50C\uB85C"
  - "\uBCD1\uC0AC"
  - "\uD0B9"
  - "\uD0B9"
  - "\uBCD1\uC0AC"
  - "\uD0B9"
  castleEntImage3:
  - {fileID: 1724245033}
