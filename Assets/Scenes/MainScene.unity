  villageSentence2:
  - "\uB124\uB188\uC774 \uBB38\uC591\uACFC \uC18C\uBB38\uC5D0 \uB300\uD574 \uBB3B\uACE0\uB2E4\uB2CC\uB2E4\uB294
    \uB188\uC778\uAC00?"
  - "\uADF8\uAC74 \uB9DE\uC9C0\uB9CC... \uB204\uAD6C\uC2ED\uB2C8\uAE4C?"
  - "\uC774\uB188\uC774 \uB9DE\uB2E4! \uCCB4\uD3EC\uD574!"
  - "\uC804 \uC544\uBB34 \uC798\uBABB\uB3C4 \uD558\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4! "
  - "\uBB38\uC591\uACFC \uC18C\uBB38\uC5D0 \uB300\uD574 \uBB3B\uB294 \uAC83 \uC790\uCCB4\uAC00
    \uC798\uBABB\uC774\uB2E4! \uC7A1\uC544\uB77C!!"
  villageSceneName2:
  - "\uACBD\uBE44\uBCD1"
  - "\uB514\uD50C\uB85C"
  - "\uACBD\uBE44\uBCD1"
