  m_Script: {fileID: 11500000, guid: 99e610799bbff8643859d045407110e1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  cutSceneSentence:
  - "\uAE30\uC5B5\uC744 \uC783\uC5B4\uBC84\uB9B0 \uC18C\uB144, \uB514\uD50C\uB85C. "
  - "\uADF8\uB294 \uADF8 \uC5B4\uB5A4\uAC83\uC870\uCC28 \uAE30\uC5B5\uD558\uC9C0
    \uBABB\uD55C \uCC44\uB85C [\uB2E4\uC774\uC544\uBAAC\uB4DC] \uB77C\uB294 \uB2E8\uC5B4
    \uD558\uB098\uB9CC\uC744 \uAE30\uC5B5\uD558\uBA70 \uC678\uB534 \uC232\uC5D0\uC11C
    \uC0B4\uC544\uAC00\uACE0\uC788\uC5C8\uB2E4"
  - "\uADF8\uB7F0 \uC18C\uB144\uC740 \uC5B4\uB290\uB0A0 \uB124\uAC00\uC9C0 \uBB38\uC591\uC744
    \uBAA8\uC73C\uBA74 \uC18C\uC6D0\uC744 \uC774\uB8E8 \uC5B4\uC900\uB2E4\uB294 \uC18C\uBB38\uC744
    \uB4E3\uAC8C\uB418\uACE0 "
  - " \uC790\uC2E0\uC758 \uAE30\uC5B5\uACFC \uB2E4\uC774\uC544\uBAAC\uB4DC\uC5D0
    \uB300\uD574\uC11C \uC54C\uAE30 \uC704\uD574 \uBB38\uC591\uC744 \uC5BB\uACE0\uC790
    \uBAA8\uD5D8\uC744 \uB5A0\uB09C\uB2E4."
