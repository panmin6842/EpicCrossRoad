--- !u!114 &93550910
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 93550902}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e297082613481694db704c2930145018, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  tutorialSentence1:
  - "\uB124\uAC00\uC9C0 \uBB38\uC591\uC744 \uCC3E\uC73C\uBA74 \uC18C\uC6D0\uC744
    \uC774\uB8E8\uC5B4\uC900\uB2E4\uB77C... \uAC01 \uBB38\uC591\uB4E4\uC758 \uC704\uCE58\uBD80\uD130
    \uD655\uC778\uD574\uBD10\uC57C\uACA0\uAD70. \uC77C\uB2E8 \uAC00\uC7A5 \uADFC\uCC98\uC758
    \uB3C4\uC2DC\uB85C \uAC00\uC11C \uC815\uBCF4\uB97C \uBAA8\uC73C\uC790"
  tutorialSceneName1:
  - "\uB514\uD50C\uB85C"
  tutorialImage1:
  - {fileID: 328566606}
  tutorialSentence2:
  - "\uC774\uAC74 \uBB50\uC9C0? "
  tutorialSceneName2:
  - "\uB514\uD50C\uB85C"
  tutorialImage2:
  - {fileID: 328566606}
  tutorialSentence3:
  - "?!?! \u3141..\uBB50\uC9C0 \uC774\uAC74?"
  - "\uAC70\uAE30 \uC790\uB124! \uBB38\uC591\uC758 \uAE30\uC6B4\uC744 \uC5B4\uB5BB\uAC8C
    \uC4F0\uACE0\uC788\uB294\uAC70\uC9C0?"
  - "\uBB38\uC591\uC758 \uAE30\uC6B4? \uADF8\uAC8C \uBB54\uC9C0\uB3C4 \uBAA8\uB985\uB2C8\uB2E4!"
  - "\uBB38\uC591\uC0C1\uD0DC\uC774\uBA74\uC11C \uADF8\uAC78 \uBAA8\uB978\uB2E4\uB2C8
    \uB9D0\uB3C4\uC548\uB418\uB294 \uC18C\uB9AC! \uCCB4\uD3EC\uD558\uACA0\uB2E4!!"
  - "\uC800\uB3C4 \uC774\uB7EC\uBA74 \uC5B4\uCA54 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4!"
  tutorialSceneName3:
  - "\uB514\uD50C\uB85C"
  - "\uACBD\uBE44\uBCD1"
  - "\uB514\uD50C\uB85C"
  - "\uACBD\uBE44\uBCD1"
  - "\uB514\uD50C\uB85C"
  tutorialImage3:
  - {fileID: 328566606}
  - {fileID: 1724245033}
  - {fileID: 328566606}
  - {fileID: 1724245033}
  - {fileID: 328566606}
  tutorialSentence4:
  - "\uC820\uC7A5... \uC544\uC9C1 \uB3C4\uC2DC\uC5D0 \uB4E4\uC5B4\uAC00\uC9C0\uB3C4
    \uC54A\uC558\uB294\uB370 \uC774\uAC8C \uBB34\uC2A8\uC77C\uC774\uC9C0.. \uAC74\uD2C0\uB81B\uB3C4
    \uADF8\uB807\uACE0 \uC774\uC0C1\uD55C\uAC8C \uB9CE\uAD70. \uB3C4\uC2DC\uC5D0
    \uB4E4\uC5B4\uAC00\uC11C \uBB3C\uC5B4\uBD10\uC57C\uACA0\uC5B4."
  tutorialSceneName4:
  - "\uB514\uD50C\uB85C"
  tutorialImage4:
  - {fileID: 245437993}
  villageSentence1:
  - "\uC5EC\uAE30\uAC00 \uC2A4\uD398\uC774\uB4DC\uC758 \uD798\uC744 \uC12C\uAE30\uB294
    \uB3C4\uC2DC\uC778\uAC00... \uC0AC\uB78C\uB4E4\uC5D0\uAC8C \uC18C\uBB38\uC5D0
    \uB300\uD574\uC11C \uBB3C\uC5B4\uBD10\uC57C\uACA0\uC5B4."
  villageSceneName1:
  - "\uB514\uD50C\uB85C"
  villageImage1:
  - {fileID: 245437993}
  npc1Sentence:
  - "\uC18C\uBB38..? \uC544 \uBB38\uC591\uC5D0 \uB300\uD55C \uC18C\uBB38\uC744 \uB9D0\uD558\uB294\uAC70\uB77C\uBA74
    \uB09C \uC544\uB294\uAC8C \uC5C6\uC5B4. \uBBF8\uC548\uD574. "
  npc1SceneName:
  - NPC 1
  npc1Image:
  - {fileID: 425747743}
  npc2Sentence:
  - "\uBB38\uC591?\uC18C\uBB38? \uCC98\uC74C\uB4E3\uB294\uAC78. \uC774\uC0C1\uD55C
    \uC18C\uBB38\uC744 \uB4E3\uACE0 \uCC3E\uC544\uC628\uAC70 \uC544\uB2C8\uC57C?"
  npc2SceneName:
  - NPC 2
  npc2Image:
  - {fileID: 425747743}
  npc3Sentence:
  - "\uC18C\uC6D0\uC744 \uC774\uB8E8\uC5B4\uC900\uB2E4\uB294 \uC18C\uBB38? \uADF8\uAC74
    \uADF8\uB0E5 \uD558\uB294\uC18C\uB9AC\uC9C0, \uADF8\uAC78 \uC9C4\uC9DC\uB85C
    \uBBFF\uB2E4\uB2C8 \uC21C\uC218\uD558\uB124. "
  npc3SceneName:
  - NPC 3
  npc3Image:
  - {fileID: 425747743}
  npc4Sentence:
  - "\uD760.... \uC0DD\uAC01\uBCF4\uB2E4 \uC4F8\uB9CC\uD55C \uC815\uBCF4\uB294 \uC5BB\uC9C0
    \uBABB\uD55C\uAC70\uAC19\uC740\uB370... \uB2E4\uB978 \uC0AC\uB78C\uB4E4\uC744
    \uCC3E\uC544\uBD10\uC57C \uD558\uB098?"
  - "\uC774\uBD10 \uC790\uB124... \uC18C\uC6D0\uC744 \uC774\uB8E8\uC5B4\uC8FC\uB294
    \uBB38\uC591\uC5D0 \uB300\uD574\uC11C \uAD00\uC2EC\uC774 \uC788\uB294\uAC00?
    \uD06D\uD06D.."
  - "!!! \uBB38\uC591\uC5D0 \uB300\uD574 \uC54C\uACE0\uC788\uB294\uAC8C \uC788\uC73C\uC2E0\uAC00\uC694?"
  - "\uC54C\uC9C0. \uC798 \uB4E3\uAC8C\uB098. \uD55C\uBC88\uB9CC \uB9D0\uD574\uC904\uD14C\uB2C8."
  - "\uC790\uB124\uAC00 \uD68D\uB4DD\uD55C\uAC74 \uBB38\uC591\uC758 \uAE30\uC6B4\uC774\uC57C.
    \uD68D\uB4DD\uD558\uBA74 \uC77C\uC2DC\uC801\uC73C\uB85C \uBB38\uC591\uC758 \uD798\uC744
    \uC0AC\uC6A9 \uD560 \uC218 \uC788\uB2E4\uB124. \uC5B4\uB5A4 \uBB38\uC591\uC744
    \uD68D\uB4DD\uD558\uB358 10\uCD08\uB3D9\uC548\uB9CC \uC720\uC9C0\uB418\uB2C8
    \uC8FC\uC758\uD558\uAC8C\uB098."
  - "\uBB38\uC591\uC758 \uAE30\uC6B4\uC744 \uD68D\uB4DD\uD558\uBA74 10\uCD08\uAC04
    \uBB34\uAE30\uC640 \uACF5\uACA9\uC774 \uAC15\uD654\uB429\uB2C8\uB2E4. \uC774\uD6C4
    \uB2E4\uB978 \uBB38\uC591\uC744 \uD68D\uB4DD\uD558\uAC70\uB098 \uB2E4\uC2DC \uBB38\uC591\uC744
    \uD68D\uB4DD\uD558\uBA74 \uC2DC\uAC04\uC774 \uAC31\uC2E0\uB429\uB2C8\uB2E4."
  - "\uBB38\uC591\uC758 \uAE30\uC6B4\uC740 \uD68D\uB4DD\uD558\uBA74 \uC5EC\uB7EC\uBC88
    \uC0AC\uC6A9 \uD560 \uC218 \uC788\uB124. \uB2E8, \uC5EC\uB7EC \uAC00\uC9C0 \uBB38\uC591\uC758
    \uAE30\uC6B4\uC744 \uD55C\uBC88\uC5D0 \uC0AC\uC6A9 \uD560 \uC218\uB294 \uC5C6\uB2E4\uB124."
  - "\uBB38\uC591\uC758 \uAE30\uC6B4\uC740 \uC5EC\uB7EC\uAC1C\uB97C \uD68D\uB4DD\uD574\uB3C4
    \uAC00\uC7A5 \uB9C8\uC9C0\uB9C9\uC5D0 \uD68D\uB4DD\uD55C \uD55C\uAC00\uC9C0\uB9CC
    \uC801\uC6A9\uB429\uB2C8\uB2E4. "
  - "\uADF8\uB7FC... \uC544\uBB34 \uBB38\uC591\uC758 \uAE30\uC6B4\uC744 \uD68D\uB4DD\uD558\uBA74
    \uADF8 \uD798\uC744 \uC7A0\uAE50 \uC4F8 \uC218 \uC788\uB2E4\uB294\uAC70\uC8E0? "
  - "\uADF8\uB807\uC9C0. \uD558\uC9C0\uB9CC \uBB38\uC591\uC758 \uD798\uC744 \uB2E4\uB8F0
    \uB54C \uC8FC\uC758\uD560 \uB0B4\uC6A9\uC774 \uC788\uB124."
  - "\uADF8\uAC8C...\uBB50\uC8E0?"
  - "\uC815\uBC29\uD5A5\uACFC \uC5ED\uBC29\uD5A5. \uAC19\uC740 \uBB38\uC591\uC744
    \uC5F0\uC18D\uC801\uC73C\uB85C \uD68D\uB4DD\uD558\uBA74 \uC808\uBC18\uC758 \uD798\uC774
    \uAC15\uD654\uB418\uB124. \uAC15\uD654\uC5D0 \uC131\uACF5\uD558\uBA74 \uC815\uBC29\uD5A5,
    \uC2E4\uD328\uD558\uBA74 \uC5ED\uBC29\uD5A5\uC73C\uB85C \uBD88\uB9AC\uC9C0."
  - "\uBB38\uC591\uC744 \uC5F0\uC18D\uC801\uC73C\uB85C \uD68D\uB4DD\uD558\uBA74 \uBC29\uD5A5
    \uC2DC\uC2A4\uD15C\uC774 \uBC1C\uC0DD\uD569\uB2C8\uB2E4. \uC131\uACF5\uC2DC \uAC15\uD55C
    \uD6A8\uACFC\uC640 \uCD94\uAC00 \uC9C0\uC18D\uC2DC\uAC04\uC774 \uC8FC\uC5B4\uC9C0\uB294
    \u201C\uC815\uBC29\uD5A5\u201D \uD6A8\uACFC\uB97C \uC5BB\uC73C\uB098 \uC2E4\uD328\uD558\uB294
    \uACBD\uC6B0 \uBB38\uC591\uC758 \uAE30\uC6B4\uC744 \uC77C\uC815\uC2DC\uAC04\uB3D9\uC548
    \uC0AC\uC6A9\uD558\uC9C0 \uBABB\uD558\uB294 \u201C\uC5ED\uBC29\uD5A5\u201D \uC0C1\uD0DC\uAC00
    \uBC1C\uC0DD\uD569\uB2C8\uB2E4."
  - "\uC815\uBC29\uD5A5\uC2DC \uAC15\uD55C \uD6A8\uACFC\uC640 \uBB38\uC591\uC758
    \uCD94\uAC00 \uC9C0\uC18D\uC2DC\uAC04\uC774 \uC8FC\uC5B4\uC9D1\uB2C8\uB2E4. \uC5ED\uBC29\uD5A5\uC2DC
    \uBB34\uAE30\uAC00 \uC6D0\uB798\uB300\uB85C \uB3CC\uC544\uAC00\uBA70 \uC77C\uC815\uC2DC\uAC04
    \uBB38\uC591\uC758 \uAE30\uC6B4\uC744 \uD68D\uB4DD \uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
  - "\uC815\uBC29\uD5A5\uC740 \uBB38\uC591\uC5D0 \uD574\uB2F9\uD558\uB294 \uD2B9\uC218\uD55C
    \uD798\uC744 \uC5BB\uACE0, \uBB38\uC591\uC758 \uAE30\uC6B4\uC744 10\uCD08\uAC04
    \uB354 \uC0AC\uC6A9 \uD560 \uC218 \uC788\uB2E4\uB124. \uC5B4\uB5A4 \uBB38\uC591\uC744
    \uD68D\uB4DD\uD588\uB294\uC9C0\uC5D0 \uB530\uB77C \uB2EC\uB77C\uC9C0\uB2C8 \uCC38\uACE0\uD558\uAC8C\uB098."
  - "\uC815\uBC29\uD5A5\uC740 \uC5B4\uB5A4 \uBB38\uC591\uC744 \uD68D\uB4DD\uD558\uC5EC
    \uBC1C\uC0DD\uD558\uC600\uB294\uC9C0\uC5D0 \uB530\uB77C \uD6A8\uACFC\uAC00 \uB2EC\uB77C\uC9D1\uB2C8\uB2E4. "
  - "\u25CF \uC2A4\uD398\uC774\uB4DC : \uB9F5 \uB0B4\uBD80\uC758 \uC801 \uBAA8\uB450\uC5D0\uAC8C
    \uB370\uBBF8\uC9C0                   \u25CF \uD558\uD2B8 : \uD50C\uB808\uC774\uC5B4\uC758
    \uCD5C\uB300 HP 30% \uD68C\uBCF5                          \u25CF \uD074\uB85C\uBC84
    : \uB9F5 \uB0B4\uBD80\uC758 \uB79C\uB364\uD55C \uC801 1\uB9C8\uB9AC\uC5D0\uAC8C
    5\uD68C \uACE0\uC815\uB370\uBBF8\uC9C0               \u25CF \uB2E4\uC774\uC544\uBAAC\uB4DC
    : 10\uCD08\uAC04 \uC77C\uC815 \uD53C\uD574\uB97C \uBB34\uD6A8\uB85C\uD558\uB294
    \uBC29\uC5B4\uB9C9 \uC0DD\uC131 "
  - "\uC5ED\uBC29\uD5A5\uC774 \uBC1C\uC0DD\uD558\uBA74 \uC7A0\uC2DC\uB3D9\uC548 \uBB38\uC591\uC758
    \uAE30\uC6B4\uC744 \uC0AC\uC6A9 \uD560 \uC218 \uC5C6\uB124. \uAC00\uC9C0\uACE0\uC788\uB358
    \uBB38\uC591\uC758 \uAE30\uC6B4\uB3C4 \uD574\uC81C\uB418\uACE0 \uC77C\uC815\uC2DC\uAC04\uB3D9\uC548
    \uBB38\uC591\uC758 \uAE30\uC6B4\uC744 \uC2B5\uB4DD\uD558\uC9C0 \uBABB\uD558\uB2C8
    \uC8FC\uC758\uD558\uAC8C\uB098."
  - "\uB0B4\uAC00 \uC804\uD574\uC904 \uC218 \uC788\uB294 \uC815\uBCF4\uB294 \uC774\uC815\uB3C4\uC120\uC778
    \uAC83 \uAC19\uAD6C\uB9CC. \uB354 \uB9CE\uC740 \uC815\uBCF4\uB294 \uC131\uC5D0\uC788\uB294
    \uD0B9\uC5D0\uAC8C \uBB3C\uC5B4\uBCF4\uB294\uAC8C \uC88B\uACA0\uB124. \uAC74\uD22C\uB97C
    \uBE44\uB124."
  - "\uC77C\uB2E8 \uB9C8\uC744\uC5D0\uC11C \uC5BB\uC744 \uC218 \uC788\uB294 \uC815\uBCF4\uB294
    \uC774\uC815\uB3C4\uC778\uAC00..."
  - "\uB354 \uB9CE\uC740 \uC815\uBCF4\uAC00 \uD544\uC694\uD574. \uC131\uC73C\uB85C\uAC00\uC790."
